SNOWFLAKE_ACCOUNT=your_account_identifier
SNOWFLAKE_USER=your_username
SNOWFLAKE_PRIVATE_KEY_PATH=/path/to/snowflake_rsa_key.p8
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=your_passphrase_here
SNOWFLAKE_ROLE=UNEARTHED_APP_ROLE
SNOWFLAKE_READONLY_ROLE=UNEARTHED_READONLY_ROLE
SNOWFLAKE_WAREHOUSE=UNEARTHED_APP_WH
SNOWFLAKE_DATABASE=UNEARTHED_DB

# Optional — local dev only
SNOWFLAKE_PASSWORD=
ALLOW_PASSWORD_AUTH=false
VITE_GOOGLE_MAPS_KEY=
ENABLE_DOCS=false
CORS_ORIGINS=
PREWARM_PROSE=false
